def send_event_log(event_type, duration=None, start_user_id=None):
    """Log event"""
    try:
        log_msg = f"[EVENT] {event_type.upper()} - {TEAM_NAME}"
        if duration:
            log_msg += f" - Duration: {duration:.2f}s"
        if start_user_id:
            log_msg += f" - User: {start_user_id}"
        logger.info(log_msg)
        print(log_msg)
    except Exception as e:
        logger.error(f"Error logging event: {e}")

def reset_system(event_type=None, end_user_id=None, end_comment=None, cancel_reason=None, breakdown=None):
    """Reset system to idle state"""
    global downtime_triggered, selected_led, event_start_time, awaiting_user_id
    global start_user_id, start_comment, sensor_alert_active, maintenance_arrival_time
    global maintenance_arrival_user_id, maintenance_state, current_status, maintenance_option
    global material_change_active, material_change_start_time
    
    if event_type and event_start_time:
        duration = time.time() - event_start_time
        send_event_log(f"END_{event_type}", duration)
    
    # Turn off all LEDs
    GPIO.output(LED_DOWNTIME, GPIO.LOW)
    GPIO.output(LED_MAINTENANCE, GPIO.LOW)
    GPIO.output(LED_BREAK, GPIO.LOW)
    GPIO.output(LED_DOWNTIME_ALERT, GPIO.HIGH)  # Active low
    GPIO.output(LED_CANCEL, GPIO.LOW)
    GPIO.output(LED_SYSTEM_RESET, GPIO.LOW)
    GPIO.output(LED_MATERIAL_CHANGE, GPIO.LOW)
    
    # Reset state
    downtime_triggered = False
    selected_led = None
    event_start_time = None
    start_user_id = None
    start_comment = None
    sensor_alert_active = False
    maintenance_arrival_time = None
    maintenance_arrival_user_id = None
    maintenance_state = None
    maintenance_option = None
    material_change_active = False
    material_change_start_time = None
    current_status = "working"
    
    logger.info("System reset to idle state")
    display_lcd_message("System Reset\nReady")
    buzz(0.1)

def selected_led_to_event_type(led):
    """Convert LED to event type"""
    if led == LED_DOWNTIME:
        return "downtime"
    elif led == LED_MAINTENANCE:
        return start_comment.lower() if start_comment else "maintenance"
    elif led == LED_BREAK:
        return "break"
    return None

# ============================================================================
# MAIN MONITORING LOOP
# ============================================================================

def monitor_buttons_and_sensors():
    """Main monitoring loop with full button handling"""
    global downtime_triggered, selected_led, event_start_time, awaiting_user_id
    global start_user_id, start_comment, end_comment, sensor_alert_active
    global maintenance_arrival_time, maintenance_arrival_user_id, maintenance_state
    global current_status, maintenance_option, material_change_active
    global material_change_start_time, last_sensor_trigger, power_on
    
    logger.info("Button and sensor monitoring started")
    display_lcd_message(f"Machine: {TEAM_NAME}\nReady")
    print("[MONITOR] Monitoring started\n")
    
    prev_sensor = GPIO.HIGH
    prev_changing_material = GPIO.HIGH
    prev_maintenance = GPIO.HIGH
    prev_break = GPIO.HIGH
    prev_cancel = GPIO.HIGH
    prev_power_cut = GPIO.HIGH
    prev_system_reset = GPIO.HIGH
    
    flash_state = False
    last_flash_time = time.time()
    last_countdown_update = time.time()
    
    try:
        while True:
            curr_sensor = read_sensor(SENSOR_OBSTACLE)
            curr_changing_material = read_button(BUTTON_CHANGING_MATERIAL)
            curr_maintenance = read_button(BUTTON_MAINTENANCE)
            curr_break = read_button(BUTTON_BREAK)
            curr_cancel = read_button(BUTTON_CANCEL)
            curr_power_cut = read_button(BUTTON_POWER_CUT)
            curr_system_reset = read_button(BUTTON_SYSTEM_RESET)
            
            # Update sensor trigger time if no obstacle
            if curr_sensor == GPIO.HIGH:
                last_sensor_trigger = time.time()
            
            # Check for downtime after 20 seconds
            if (time.time() - last_sensor_trigger > 20 and not downtime_triggered 
                and not selected_led and not material_change_active):
                logger.info("Downtime alert triggered")
                print("[ALERT] Downtime detected!")
                display_lcd_message("Downtime Alert!\nSelect Event")
                buzz(0.3)
                downtime_triggered = True
                current_status = "downtime"
                
                # Flash all LEDs
                GPIO.output(LED_DOWNTIME, GPIO.HIGH)
                GPIO.output(LED_MAINTENANCE, GPIO.HIGH)
                GPIO.output(LED_BREAK, GPIO.HIGH)
                GPIO.output(LED_DOWNTIME_ALERT, GPIO.LOW)  # Active low
                GPIO.output(LED_CANCEL, GPIO.HIGH)
                GPIO.output(LED_SYSTEM_RESET, GPIO.HIGH)
                GPIO.output(LED_MATERIAL_CHANGE, GPIO.HIGH)
            
            # Material change timeout (180 seconds)
            if (material_change_active and 
                time.time() - material_change_start_time > 180 and not downtime_triggered):
                logger.info("Material change timeout")
                print("[MATERIAL] Timeout")
                display_lcd_message("Timeout!\nDowntime Alert")
                buzz(0.2)
                
                downtime_triggered = True
                material_change_active = False
                material_change_start_time = None
                current_status = "downtime"
                
                GPIO.output(LED_DOWNTIME, GPIO.HIGH)
                GPIO.output(LED_MAINTENANCE, GPIO.HIGH)
                GPIO.output(LED_BREAK, GPIO.HIGH)
                GPIO.output(LED_DOWNTIME_ALERT, GPIO.LOW)
                GPIO.output(LED_CANCEL, GPIO.HIGH)
                GPIO.output(LED_SYSTEM_RESET, GPIO.HIGH)
                GPIO.output(LED_MATERIAL_CHANGE, GPIO.HIGH)
            
            # Material change countdown
            if material_change_active and time.time() - last_countdown_update >= 1:
                seconds_remaining = int(180 - (time.time() - material_change_start_time))
                if seconds_remaining >= 0:
                    display_countdown(seconds_remaining)
                last_countdown_update = time.time()
            
            # LED flashing for alerts
            if time.time() - last_flash_time >= 0.25:
                flash_state = not flash_state
                last_flash_time = time.time()
                
                if sensor_alert_active:
                    GPIO.output(LED_DOWNTIME, GPIO.HIGH if flash_state else GPIO.LOW)
                    GPIO.output(LED_MAINTENANCE, GPIO.HIGH if flash_state else GPIO.LOW)
                    GPIO.output(LED_BREAK, GPIO.HIGH if flash_state else GPIO.LOW)
                elif selected_led and selected_led in [LED_DOWNTIME, LED_BREAK]:
                    GPIO.output(selected_led, GPIO.HIGH if flash_state else GPIO.LOW)
            
            # ================================================================
            # POWER CUT BUTTON
            # ================================================================
            if prev_power_cut == GPIO.HIGH and curr_power_cut == GPIO.LOW:
                buzz(0.1)
                if power_on:
                    cut_power()
                else:
                    restore_power()
            
            # ================================================================
            # MATERIAL CHANGE BUTTON
            # ================================================================
            if not awaiting_user_id:
                if prev_changing_material == GPIO.HIGH and curr_changing_material == GPIO.LOW:
                    buzz(0.1)
                    logger.info("Material change button pressed")
                    print("[BUTTON] Material Change pressed")
                    
                    if material_change_active:
                        material_change_active = False
                        material_change_start_time = None
                        logger.info("Material change stopped")
                        reset_system()
                        display_lcd_message("Material Change\nStopped")
                    elif selected_led == LED_DOWNTIME:
                        awaiting_user_id = True
                        end_user_id = get_user_id("End Downtime\nUser ID:")
                        end_comment = get_comment("End Comment:")
                        reset_system("downtime", end_user_id, end_comment)
                        awaiting_user_id = False
                    elif downtime_triggered and not selected_led:
                        selected_led = LED_DOWNTIME
                        downtime_triggered = False
                        event_start_time = time.time()
                        awaiting_user_id = True
                        
                        GPIO.output(LED_DOWNTIME, GPIO.HIGH)
                        GPIO.output(LED_MAINTENANCE, GPIO.LOW)
                        GPIO.output(LED_BREAK, GPIO.LOW)
                        GPIO.output(LED_DOWNTIME_ALERT, GPIO.HIGH)
                        GPIO.output(LED_CANCEL, GPIO.LOW)
                        GPIO.output(LED_SYSTEM_RESET, GPIO.LOW)
                        
                        start_user_id = get_user_id("Start Downtime\nUser ID:")
                        start_comment = get_comment("Start Comment:")
                        current_status = "downtime"
                        send_event_log("downtime", start_user_id=start_user_id)
                        display_lcd_message("Downtime\nStarted")
                        awaiting_user_id = False
                    else:
                        material_change_active = True
                        material_change_start_time = time.time()
                        last_countdown_update = time.time()
                        logger.info("Material change started")
                        
                        GPIO.output(LED_MATERIAL_CHANGE, GPIO.HIGH)
                        display_countdown(180)
                        send_event_log("material_change")
                
                # ================================================================
                # MAINTENANCE BUTTON
                # ================================================================
                elif prev_maintenance == GPIO.HIGH and curr_maintenance == GPIO.LOW:
                    buzz(0.1)
                    logger.info("Maintenance button pressed")
                    print("[BUTTON] Maintenance pressed")
                    
                    if selected_led == LED_MAINTENANCE:
                        if maintenance_state == "started":
                            awaiting_user_id = True
                            maintenance_arrival_user_id = get_user_id("Maintenance Arrival\nUser ID:")
                            maintenance_arrival_time = time.time()
                            logger.info("Maintenance arrived")
                            maintenance_state = "arrived"
                            display_lcd_message("Maintenance\nArrived")
                            send_event_log("maintenance_arrival")
                            awaiting_user_id = False
                        elif maintenance_state == "arrived":
                            awaiting_user_id = True
                            end_user_id = get_user_id("End Maintenance\nUser ID:")
                            breakdown_type = None
                            if maintenance_option == "Maintenance":
                                breakdown_type = get_maintenance_type()
                                if breakdown_type:
                                    start_comment = breakdown_type
                            end_comment = get_comment("End Comment:")
                            reset_system(start_comment.lower() if start_comment else "maintenance", 
                                        end_user_id, end_comment, breakdown=breakdown_type)
                            awaiting_user_id = False
                    elif downtime_triggered and not selected_led:
                        selected_led = LED_MAINTENANCE
                        downtime_triggered = False
                        event_start_time = time.time()
                        awaiting_user_id = True
                        
                        GPIO.output(LED_DOWNTIME, GPIO.LOW)
                        GPIO.output(LED_MAINTENANCE, GPIO.HIGH)
                        GPIO.output(LED_BREAK, GPIO.LOW)
                        GPIO.output(LED_DOWNTIME_ALERT, GPIO.HIGH)
                        GPIO.output(LED_CANCEL, GPIO.LOW)
                        GPIO.output(LED_SYSTEM_RESET, GPIO.LOW)
                        
                        start_user_id = get_user_id("Start Maintenance\nUser ID:")
                        maintenance_option = get_maintenance_option()
                        start_comment = maintenance_option
                        maintenance_state = "started"
                        current_status = start_comment.lower()
                        send_event_log(start_comment.lower(), start_user_id=start_user_id)
                        display_lcd_message(f"{start_comment}\nStarted")
                        awaiting_user_id = False
                
                # ================================================================
                # BREAK BUTTON
                # ================================================================
                elif prev_break == GPIO.HIGH and curr_break == GPIO.LOW:
                    buzz(0.1)
                    logger.info("Break button pressed")
                    print("[BUTTON] Break pressed")
                    
                    if selected_led == LED_BREAK:
                        awaiting_user_id = True
                        end_user_id = get_user_id("End Break\nUser ID:")
                        end_comment = get_comment("End Comment:")
                        reset_system("break", end_user_id, end_comment)
                        awaiting_user_id = False
                    elif downtime_triggered and not selected_led:
                        selected_led = LED_BREAK
                        downtime_triggered = False
                        event_start_time = time.time()
                        awaiting_user_id = True
                        
                        GPIO.output(LED_DOWNTIME, GPIO.LOW)
                        GPIO.output(LED_MAINTENANCE, GPIO.LOW)
                        GPIO.output(LED_BREAK, GPIO.HIGH)
                        GPIO.output(LED_DOWNTIME_ALERT, GPIO.HIGH)
                        GPIO.output(LED_CANCEL, GPIO.LOW)
                        GPIO.output(LED_SYSTEM_RESET, GPIO.LOW)
                        
                        start_user_id = get_user_id("Start Break\nUser ID:")
                        start_comment = get_comment("Start Comment:")
                        current_status = "break"
                        send_event_log("break", start_user_id=start_user_id)
                        display_lcd_message("Break\nStarted")
                        awaiting_user_id = False
                
                # ================================================================
                # CANCEL BUTTON
                # ================================================================
                elif prev_cancel == GPIO.HIGH and curr_cancel == GPIO.LOW:
                    buzz(0.2)
                    logger.info("Cancel button pressed")
                    print("[BUTTON] Cancel pressed")
                    
                    if selected_led:
                        awaiting_user_id = True
                        cancel_reason = get_comment("Cancellation\nReason:")
                        end_user_id = get_user_id("Cancel User ID:")
                        breakdown_type = None
                        if selected_led == LED_MAINTENANCE and maintenance_option == "Maintenance":
                            breakdown_type = get_maintenance_type()
                            if breakdown_type:
                                start_comment = breakdown_type
                        reset_system(selected_led_to_event_type(selected_led), end_user_id, 
                                   cancel_reason=cancel_reason, breakdown=breakdown_type)
                        display_lcd_message("Event\nCancelled")
                        awaiting_user_id = False
                
                # ================================================================
                # SYSTEM RESET BUTTON
                # ================================================================
                elif prev_system_reset == GPIO.HIGH and curr_system_reset == GPIO.LOW:
                    buzz(0.1)
                    logger.info("System reset button pressed")
                    print("[BUTTON] System Reset pressed")
                    reset_system()
            
            # Update previous states
            prev_sensor = curr_sensor
            prev_changing_material = curr_changing_material
            prev_maintenance = curr_maintenance
            prev_break = curr_break
            prev_cancel = curr_cancel
            prev_power_cut = curr_power_cut
            prev_system_reset = curr_system_reset
            
            time.sleep(0.01)
    
    except KeyboardInterrupt:
        logger.info("Monitoring stopped by user")
        print("\n[MONITOR] Stopped")
    except Exception as e:
        logger.error(f"Monitor error: {e}\n{traceback.format_exc()}")
        print(f"[ERROR] {e}")

