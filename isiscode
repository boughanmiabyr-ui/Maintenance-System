def get_input_from_keyboard(prompt="Enter: "):
    """Get input from keyboard"""
    display_lcd_message(prompt)
    try:
        input_str = input(prompt)
        return input_str.strip() if input_str else ""
    except:
        return ""

def get_user_id(prompt="Enter User ID:"):
    """Get user ID"""
    user_id = get_input_from_keyboard(prompt)
    return user_id if user_id else "N/A"

def get_comment(prompt="Enter Comment:"):
    """Get comment"""
    comment = get_input_from_keyboard(prompt)
    return comment if comment else ""

def get_maintenance_option():
    """Get maintenance type option"""
    options = {"1": "Maintenance", "2": "IT", "3": "Production", "4": "Quality"}
    display_lcd_message("1 Maintenance\n2 IT 3 Prod 4")
    print("\nSelect 1-4: ", end="")
    try:
        input_str = input()
        if input_str in options:
            display_lcd_message(f"Selected\n{options[input_str]}")
            logger.info(f"Maintenance: {options[input_str]}")
            return options[input_str]
        return "Maintenance"
    except:
        return "Maintenance"

def get_maintenance_type():
    """Get maintenance type"""
    options = {"1": "Curative", "2": "Corrective", "3": "Preventive"}
    display_lcd_message("1 Curative\n2 Correct 3 Prev")
    print("\nSelect 1-3: ", end="")
    try:
        input_str = input()
        if input_str in options:
            display_lcd_message(f"Selected\n{options[input_str]}")
            logger.info(f"Type: {options[input_str]}")
