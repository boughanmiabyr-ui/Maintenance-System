    GPIO.output(LED_MATERIAL_CHANGE, GPIO.LOW)

def cut_power():
    """Cut machine power"""
    global power_on, current_status
    power_on = False
    current_status = "offline"
    GPIO.output(RELAY_POWER, GPIO.HIGH)
    logger.info("Power cut: Relay OFF")
    display_lcd_message("Power Cut!\nMachine OFF")
    buzz(0.3)

def restore_power():
    """Restore machine power"""
    global power_on, current_status
    power_on = True
    current_status = "working"
    GPIO.output(RELAY_POWER, GPIO.LOW)
    logger.info("Power restored: Relay ON")
    display_lcd_message("Power Restored\nMachine ON")
    buzz(0.1)

